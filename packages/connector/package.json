{
  "name": "midnight-wallet-connector",
  "version": "0.1.0",
  "type": "module",
  "description": "Client library for connecting DApps to the Midnight CLI wallet over WebSocket JSON-RPC",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/nel349/midnight-wallet-cli.git",
    "directory": "packages/connector"
  },
  "keywords": [
    "midnight",
    "blockchain",
    "wallet",
    "dapp-connector",
    "json-rpc",
    "websocket"
  ],
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm run test"
  },
  "peerDependencies": {
    "ws": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "ws": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/ws": "^8.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "ws": "^8.19.0"
  }
}
